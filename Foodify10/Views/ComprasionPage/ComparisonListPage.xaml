<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Foodify10.ViewModels"
             xmlns:models="clr-namespace:Foodify10.Models"
             x:Class="Foodify10.ComparisonListPage"
             x:DataType="viewmodels:ComparisonListPageViewModel"
             Title="Сравнение товаров"
             BackgroundColor="#F4F6F8">
    <Grid RowDefinitions="*,Auto">

        <CollectionView Grid.Row="0"
                        ItemsSource="{Binding Groups}"
                        SelectionMode="None">
            <CollectionView.Footer>
                <BoxView HeightRequest="100" BackgroundColor="Transparent" />
            </CollectionView.Footer>
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Padding="40" Spacing="15" Margin="0,80,0,0">
                    <Label Text="⚖️" FontSize="64" HorizontalOptions="Center" />
                    <Label Text="Нет списков для сравнения" FontAttributes="Bold" FontSize="18" TextColor="#2C3E50" HorizontalOptions="Center" />
                    <Label Text="Добавляйте продукты в группы, чтобы сравнить их состав, калорийность и цены." 
                           TextColor="#7F8C8D" FontSize="14" HorizontalTextAlignment="Center" LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ComparisonGroup">
                    <ContentView Padding="20,0,20,12">
                        <Border BackgroundColor="White"
                                StrokeThickness="0"
                                Padding="15">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>

                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05" />
                            </Border.Shadow>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenGroupCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">

                                <Frame Grid.Column="0" BackgroundColor="#E8F8F5" CornerRadius="12" HeightRequest="48" WidthRequest="48" Padding="0" BorderColor="Transparent" VerticalOptions="Center">
                                    <Label Text="⚖️" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Frame>

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                    <Label Text="{Binding Name}"
                                           TextColor="#2C3E50"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           LineBreakMode="TailTruncation"/>

                                    <Border BackgroundColor="#F8F9FA" StrokeThickness="0" Padding="8,2" HorizontalOptions="Start">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="6" />
                                        </Border.StrokeShape>
                                        <Label Text="{Binding Products.Count, StringFormat='Продуктов: {0}'}" 
                                               FontSize="11" TextColor="#7F8C8D" FontAttributes="Bold" />
                                    </Border>
                                </VerticalStackLayout>

                                <Label Grid.Column="2"
                                       Text="❯"
                                       FontSize="18"
                                       TextColor="#BDC3C7"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </ContentView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="1"
                IsVisible="{Binding HasGroups}"
                Text="Очистить все списки"
                Margin="20,10,20,30"
                BackgroundColor="#FDF2F2"
                TextColor="#E74C3C"
                HeightRequest="50"
                CornerRadius="12"
                FontAttributes="Bold"
                FontSize="15"
                Command="{Binding ClearAllCommand}">
            <Button.Shadow>
                <Shadow Brush="#E74C3C" Offset="0,4" Radius="8" Opacity="0.1" />
            </Button.Shadow>
        </Button>

    </Grid>
</ContentPage>