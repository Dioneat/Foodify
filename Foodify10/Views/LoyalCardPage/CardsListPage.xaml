<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Foodify10.ViewModels"
             xmlns:models="clr-namespace:Foodify10.Models"
             x:Class="Foodify10.CardsListPage"
             x:Name="PageRoot"
             x:DataType="viewmodels:CardsListPageViewModel"
             Title="Мои карты"
             BackgroundColor="#F4F6F8">
    <Grid>
        <VerticalStackLayout>
            <Label Text="Ваши карты лояльности"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#1C2833"
                   Margin="20,20,20,10"/>

            <CollectionView ItemsSource="{Binding Cards}"
                            SelectedItem="{Binding SelectedCard, Mode=TwoWay}"
                            SelectionMode="Single">

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Padding="40" Spacing="15" Margin="0,80,0,0">
                        <Label Text="💳" FontSize="64" HorizontalOptions="Center" />
                        <Label Text="Нет добавленных карт" FontAttributes="Bold" FontSize="18" TextColor="#2C3E50" HorizontalOptions="Center" />
                        <Label Text="Добавьте свои скидочные карты, чтобы они всегда были под рукой на кассе." 
                               TextColor="#7F8C8D" FontSize="14" HorizontalTextAlignment="Center" LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.Footer>
                    <BoxView HeightRequest="100" BackgroundColor="Transparent" />
                </CollectionView.Footer>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:LoyaltyCard">
                        <SwipeView Margin="20,0,20,12">
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="Удалить"
                                               BackgroundColor="#E74C3C"
                                               Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.DeleteCardCommand}"
                                               CommandParameter="{Binding .}" />
                                </SwipeItems>
                            </SwipeView.RightItems>

                            <Border BackgroundColor="White"
                                    StrokeThickness="0"
                                    Padding="15">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="16" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05" />
                                </Border.Shadow>

                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">

                                    <Frame Grid.Column="0" 
                                           BackgroundColor="{Binding CardColor}" 
                                           CornerRadius="12" 
                                           HeightRequest="50" 
                                           WidthRequest="50" 
                                           Padding="0" 
                                           BorderColor="Transparent" 
                                           VerticalOptions="Center">
                                        <Label Text="💳" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Frame>

                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                        <Label Text="{Binding Name}"
                                               FontAttributes="Bold"
                                               TextColor="#2C3E50"
                                               FontSize="16"
                                               LineBreakMode="TailTruncation"/>
                                        <Label Text="{Binding CardNumber}"
                                               TextColor="#7F8C8D"
                                               FontSize="13"
                                               FontFamily="Monospace"/>
                                    </VerticalStackLayout>

                                    <Label Grid.Column="2"
                                           Text="❯"
                                           FontSize="18"
                                           TextColor="#BDC3C7"
                                           FontAttributes="Bold"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>

        <Button Text="➕ Добавить карту"
                Command="{Binding AddCardCommand}"
                BackgroundColor="#27AE60"
                TextColor="White"
                HeightRequest="56"
                CornerRadius="28"
                Padding="25,0"
                FontAttributes="Bold"
                FontSize="15"
                HorizontalOptions="Center"
                VerticalOptions="End"
                Margin="0,0,0,30">
            <Button.Shadow>
                <Shadow Brush="#27AE60" Offset="0,4" Radius="8" Opacity="0.4" />
            </Button.Shadow>
        </Button>
    </Grid>

</ContentPage>