<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Foodify10.ViewModels"
             x:Class="Foodify10.MenuPage"
             x:DataType="viewmodels:MenuPageViewModel"
             BackgroundColor="#F6FBF8">

    <ContentPage.Resources>
        <Style x:Key="MenuCardStyle" TargetType="Border">
            <Setter Property="BackgroundColor" Value="#27AE60" />
            <Setter Property="StrokeThickness" Value="0" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="HeightRequest" Value="150" />
        </Style>

        <Style x:Key="MenuIconStyle" TargetType="Image">
            <Setter Property="WidthRequest" Value="34" />
            <Setter Property="HeightRequest" Value="34" />
            <Setter Property="HorizontalOptions" Value="Center" />
            <Setter Property="Aspect" Value="AspectFit" />
        </Style>

        <Style x:Key="MenuTitleStyle" TargetType="Label">
            <Setter Property="TextColor" Value="White" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style x:Key="MenuSubtitleStyle" TargetType="Label">
            <Setter Property="TextColor" Value="#EAF7EF" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Border BackgroundColor="#27AE60"
                    StrokeThickness="0"
                    Padding="22">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="8">
                    <Label Text="Меню Foodify"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="White" />

                    <Label Text="Полезные сервисы для покупок, анализа продуктов и хранения данных"
                           FontSize="14"
                           TextColor="#EAF7EF"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*"
                  RowDefinitions="Auto,Auto,Auto"
                  ColumnSpacing="14"
                  RowSpacing="14">

                <Border Grid.Row="0"
                        Grid.Column="0"
                        Style="{StaticResource MenuCardStyle}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="22" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#16000000" Offset="0,8" Radius="14" Opacity="0.18" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenBmrCalculatorCommand}" />
                    </Border.GestureRecognizers>

                    <VerticalStackLayout VerticalOptions="Center" Spacing="10">
                        <Image Source="calculator_icon.png" Style="{StaticResource MenuIconStyle}" />
                        <Label Text="Калькулятор КБЖУ"
                               Style="{StaticResource MenuTitleStyle}" />
                        <Label Text="Рассчитайте норму калорий и БЖУ"
                               Style="{StaticResource MenuSubtitleStyle}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="0"
                        Grid.Column="1"
                        Style="{StaticResource MenuCardStyle}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="22" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#16000000" Offset="0,8" Radius="14" Opacity="0.18" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenDiscountCardsCommand}" />
                    </Border.GestureRecognizers>

                    <VerticalStackLayout VerticalOptions="Center" Spacing="10">
                        <Image Source="cards_icon.png" Style="{StaticResource MenuIconStyle}" />
                        <Label Text="Мои карты"
                               Style="{StaticResource MenuTitleStyle}" />
                        <Label Text="Храните карты лояльности в одном месте"
                               Style="{StaticResource MenuSubtitleStyle}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1"
                        Grid.Column="0"
                        Style="{StaticResource MenuCardStyle}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="22" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#16000000" Offset="0,8" Radius="14" Opacity="0.18" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenShoppingListsCommand}" />
                    </Border.GestureRecognizers>

                    <VerticalStackLayout VerticalOptions="Center" Spacing="10">
                        <Image Source="shoppedlist_icon.png" Style="{StaticResource MenuIconStyle}" />
                        <Label Text="Списки покупок"
                               Style="{StaticResource MenuTitleStyle}" />
                        <Label Text="Создавайте и сохраняйте списки"
                               Style="{StaticResource MenuSubtitleStyle}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1"
                        Grid.Column="1"
                        Style="{StaticResource MenuCardStyle}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="22" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#16000000" Offset="0,8" Radius="14" Opacity="0.18" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenComparisonCommand}" />
                    </Border.GestureRecognizers>

                    <VerticalStackLayout VerticalOptions="Center" Spacing="10">
                        <Image Source="compares_icon.png" Style="{StaticResource MenuIconStyle}" />
                        <Label Text="Сравнение"
                               Style="{StaticResource MenuTitleStyle}" />
                        <Label Text="Сравнивайте продукты по ключевым параметрам"
                               Style="{StaticResource MenuSubtitleStyle}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="2"
                        Grid.ColumnSpan="2"
                        BackgroundColor="#27AE60"
                        StrokeThickness="0"
                        Padding="20"
                        HeightRequest="120">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="22" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#16000000" Offset="0,8" Radius="14" Opacity="0.18" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenSettingsCommand}" />
                    </Border.GestureRecognizers>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                        <Image Source="settings_icon.png"
                               WidthRequest="32"
                               HeightRequest="32"
                               Aspect="AspectFit"
                               VerticalOptions="Center" />

                        <VerticalStackLayout Grid.Column="1"
                                             VerticalOptions="Center"
                                             Spacing="4">
                            <Label Text="Настройки"
                                   TextColor="White"
                                   FontAttributes="Bold"
                                   FontSize="18" />
                            <Label Text="Уведомления, данные, поведение сканера и другие параметры"
                                   TextColor="#EAF7EF"
                                   FontSize="13"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>