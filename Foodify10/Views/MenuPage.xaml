<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Foodify10.ViewModels"
             x:Class="Foodify10.MenuPage"
             x:DataType="viewmodels:MenuPageViewModel"
             BackgroundColor="#F6FBF8"
             Title="Меню">

    <ContentPage.Resources>
        <Style x:Key="MenuCardStyle" TargetType="Border">
            <Setter Property="BackgroundColor" Value="White" />
            <Setter Property="StrokeThickness" Value="0" />
            <Setter Property="Padding" Value="15" />
            <Setter Property="HeightRequest" Value="160" />
        </Style>

        <Style x:Key="MenuIconStyle" TargetType="Image">
            <Setter Property="WidthRequest" Value="40" />
            <Setter Property="HeightRequest" Value="40" />
            <Setter Property="HorizontalOptions" Value="Center" />
            <Setter Property="Aspect" Value="AspectFit" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style x:Key="MenuTitleStyle" TargetType="Label">
            <Setter Property="TextColor" Value="#2C3E50" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style x:Key="MenuSubtitleStyle" TargetType="Label">
            <Setter Property="TextColor" Value="#7F8C8D" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="LineBreakMode" Value="WordWrap" />
            <Setter Property="MaxLines" Value="2" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <Border BackgroundColor="#27AE60"
                    StrokeThickness="0"
                    Padding="24">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#27AE60" Offset="0,6" Radius="12" Opacity="0.3" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="8">
                    <Label Text="Сервисы Foodify"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="White" />

                    <Label Text="Инструменты для покупок, анализа продуктов и заботы о здоровье."
                           FontSize="14"
                           TextColor="#EAF7EF"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*"
                  RowDefinitions="Auto,Auto,Auto"
                  ColumnSpacing="15"
                  RowSpacing="15">

                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource MenuCardStyle}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenBmrCalculatorCommand}" />
                    </Border.GestureRecognizers>

                    <VerticalStackLayout VerticalOptions="Center" Spacing="5">
                        <Image Source="calculator_icon.png" Style="{StaticResource MenuIconStyle}" />
                        <Label Text="КБЖУ" Style="{StaticResource MenuTitleStyle}" />
                        <Label Text="Норма калорий и БЖУ" Style="{StaticResource MenuSubtitleStyle}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource MenuCardStyle}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenBmiCalculatorCommand}" />
                    </Border.GestureRecognizers>

                    <VerticalStackLayout VerticalOptions="Center" Spacing="5">
                        <Image Source="bmi_icon.png" Style="{StaticResource MenuIconStyle}" />
                        <Label Text="Индекс массы" Style="{StaticResource MenuTitleStyle}" />
                        <Label Text="Проверка веса и роста" Style="{StaticResource MenuSubtitleStyle}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource MenuCardStyle}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenDiscountCardsCommand}" />
                    </Border.GestureRecognizers>

                    <VerticalStackLayout VerticalOptions="Center" Spacing="5">
                        <Image Source="cards_icon.png" Style="{StaticResource MenuIconStyle}" />
                        <Label Text="Мои карты" Style="{StaticResource MenuTitleStyle}" />
                        <Label Text="Карты лояльности" Style="{StaticResource MenuSubtitleStyle}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource MenuCardStyle}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenShoppingListsCommand}" />
                    </Border.GestureRecognizers>

                    <VerticalStackLayout VerticalOptions="Center" Spacing="5">
                        <Image Source="shoppedlist_icon.png" Style="{StaticResource MenuIconStyle}" />
                        <Label Text="Списки" Style="{StaticResource MenuTitleStyle}" />
                        <Label Text="Ваши покупки" Style="{StaticResource MenuSubtitleStyle}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource MenuCardStyle}" HeightRequest="100">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenComparisonCommand}" />
                    </Border.GestureRecognizers>

                    <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                        <Image Grid.Column="0" Source="compares_icon.png" WidthRequest="40" HeightRequest="40" Aspect="AspectFit" Margin="0,0,15,0"/>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="Сравнение товаров" Style="{StaticResource MenuTitleStyle}" HorizontalTextAlignment="Start"/>
                            <Label Text="Сравнивайте продукты по параметрам" Style="{StaticResource MenuSubtitleStyle}" HorizontalTextAlignment="Start"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="❯" FontSize="20" TextColor="#BDC3C7" VerticalOptions="Center" FontAttributes="Bold"/>
                    </Grid>
                </Border>

            </Grid>

            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    Padding="20"
                    Margin="0,10,0,20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenSettingsCommand}" />
                </Border.GestureRecognizers>

                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">
                    <Frame Grid.Column="0" CornerRadius="12" HeightRequest="48" WidthRequest="48" Padding="0" IsClippedToBounds="True" BackgroundColor="#F8F9FA" BorderColor="Transparent">
                        <Image Source="settings_icon.png" WidthRequest="24" HeightRequest="24" Aspect="AspectFit" VerticalOptions="Center" HorizontalOptions="Center" />
                    </Frame>

                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                        <Label Text="Настройки" TextColor="#2C3E50" FontAttributes="Bold" FontSize="16" />
                        <Label Text="Уведомления, данные и параметры" TextColor="#7F8C8D" FontSize="12" LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <Label Grid.Column="2" Text="❯" FontSize="20" TextColor="#BDC3C7" VerticalOptions="Center" FontAttributes="Bold"/>
                </Grid>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>