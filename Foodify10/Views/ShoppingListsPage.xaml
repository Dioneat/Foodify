<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Foodify10.ViewModels"
             xmlns:models="clr-namespace:Foodify10.Models"
             x:Class="Foodify10.Views.ShoppingListsPage"
             x:DataType="viewmodels:ShoppingListsPageViewModel"
             Title="Мои списки"
             BackgroundColor="White">

    <Grid RowDefinitions="Auto,*" Padding="20">
        <Button Text="Создать новый список"
                Command="{Binding CreateNewListCommand}"
                BackgroundColor="#27AE60"
                TextColor="White"
                HeightRequest="50"
                CornerRadius="12"/>

        <CollectionView Grid.Row="1"
                        Margin="0,15,0,0"
                        ItemsSource="{Binding Lists}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ShoppingListModel">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Удалить"
                                           BackgroundColor="Red"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteListCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Border Stroke="#E0E0E0"
                                StrokeThickness="1"
                                BackgroundColor="White"
                                Padding="15"
                                Margin="0,0,0,12">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenListCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="*,Auto"
                                  RowDefinitions="Auto,Auto">
                                <Label Text="{Binding Title}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="Black" />

                                <Label Grid.Row="1"
                                       Text="{Binding Items.Count, StringFormat='Товаров: {0}'}"
                                       FontSize="13"
                                       TextColor="Gray" />

                                <Label Grid.Column="1"
                                       Grid.RowSpan="2"
                                       Text="›"
                                       FontSize="24"
                                       TextColor="#27AE60"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>