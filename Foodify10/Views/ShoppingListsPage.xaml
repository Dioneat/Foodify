<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Foodify10.ViewModels"
             xmlns:models="clr-namespace:Foodify10.Models"
             x:Class="Foodify10.Views.ShoppingListsPage"
             x:Name="PageRoot"
             x:DataType="viewmodels:ShoppingListsPageViewModel"
             Title="Мои списки"
             BackgroundColor="#F4F6F8">
    <Grid>

        <CollectionView ItemsSource="{Binding Lists}"
                        SelectionMode="None">
            <CollectionView.Footer>
                <BoxView HeightRequest="100" BackgroundColor="Transparent" />
            </CollectionView.Footer>
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Padding="40" Spacing="15" Margin="0,100,0,0">
                    <Label Text="🛒" FontSize="64" HorizontalOptions="Center" />
                    <Label Text="У вас пока нет списков" FontAttributes="Bold" FontSize="18" TextColor="#2C3E50" HorizontalOptions="Center" />
                    <Label Text="Создайте свой первый список покупок, чтобы ничего не забыть в магазине." 
                           TextColor="#7F8C8D" FontSize="14" HorizontalTextAlignment="Center" LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ShoppingListModel">
                    <SwipeView Margin="20,0,20,12">
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Удалить"
                                           BackgroundColor="#E74C3C"
                                           Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.DeleteListCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Border BackgroundColor="White"
                                StrokeThickness="0"
                                Padding="15">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>

                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05" />
                            </Border.Shadow>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.OpenListCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">

                                <Frame Grid.Column="0" BackgroundColor="#E8F8F5" CornerRadius="12" HeightRequest="48" WidthRequest="48" Padding="0" BorderColor="Transparent" VerticalOptions="Center">
                                    <Label Text="📝" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Frame>

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                    <Label Text="{Binding Title}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#2C3E50"
                                           LineBreakMode="TailTruncation" />

                                    <HorizontalStackLayout Spacing="8">
                                        <Border BackgroundColor="#F8F9FA" StrokeThickness="0" Padding="8,2">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="6" />
                                            </Border.StrokeShape>
                                            <Label Text="{Binding Items.Count, StringFormat='Товаров: {0}'}" FontSize="11" TextColor="#7F8C8D" FontAttributes="Bold" />
                                        </Border>

                                        <Label Text="{Binding CreatedAt, StringFormat='{0:dd.MM.yyyy}'}"
                                               FontSize="12"
                                               TextColor="#BDC3C7"
                                               VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <Label Grid.Column="2"
                                       Text="❯"
                                       FontSize="18"
                                       TextColor="#BDC3C7"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="➕ Создать список"
                Command="{Binding CreateNewListCommand}"
                BackgroundColor="#27AE60"
                TextColor="White"
                HeightRequest="56"
                CornerRadius="28"
                Padding="25,0"
                FontAttributes="Bold"
                FontSize="15"
                HorizontalOptions="Center"
                VerticalOptions="End"
                Margin="0,0,0,30">
            <Button.Shadow>
                <Shadow Brush="#27AE60" Offset="0,4" Radius="8" Opacity="0.4" />
            </Button.Shadow>
        </Button>

    </Grid>
</ContentPage>