<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Foodify10.ViewModels"
             xmlns:models="clr-namespace:Foodify10.Models"
             xmlns:json="clr-namespace:Foodify10.Models.JsonModels"
             x:Class="Foodify10.MainPage"
             x:Name="PageRoot"
             x:DataType="viewmodels:MainPageViewModel"
             BackgroundColor="#F4F6F8">

    <ContentPage.Resources>
        <Style x:Key="SkeletonBox" TargetType="BoxView">
            <Setter Property="BackgroundColor" Value="#E1E9EE" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20,20,20,40" Spacing="25">

            <Label Text="Добро пожаловать! 👋"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="#1C2833"/>

            <Border BackgroundColor="White" Padding="5,0" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.05"/>
                </Border.Shadow>

                <SearchBar Placeholder="Поиск продуктов, списков, статей..." 
                           BackgroundColor="Transparent"
                           CancelButtonColor="#7F8C8D"
                           PlaceholderColor="#BDC3C7"
                           TextColor="#2C3E50"/>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                <Border Grid.Column="0" BackgroundColor="#E8F8F5" Padding="15" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenShoppingListsCommand}" />
                    </Border.GestureRecognizers>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="🛒" FontSize="32"/>
                        <Label Text="Списки" FontAttributes="Bold" FontSize="16" TextColor="#27AE60"/>
                        <Label Text="Ваши корзины" FontSize="12" TextColor="#5D6D7E"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1" BackgroundColor="#FEF9E7" Padding="15" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer />
                    </Border.GestureRecognizers>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="⭐" FontSize="32"/>
                        <Label Text="Избранное" FontAttributes="Bold" FontSize="16" TextColor="#F1C40F"/>
                        <Label Text="Лучшие товары" FontSize="12" TextColor="#5D6D7E"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <VerticalStackLayout Spacing="10">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="История" FontAttributes="Bold" FontSize="18" TextColor="#2C3E50" VerticalOptions="Center"/>
                    <Label Grid.Column="1" Text="Все" TextColor="#3498DB" FontSize="14" FontAttributes="Bold" VerticalOptions="Center"/>
                </Grid>

                <CollectionView ItemsSource="{Binding RecentScans}"
                                SelectedItem="{Binding SelectedHistoryItem, Mode=TwoWay}"
                                SelectionMode="Single">

                    <CollectionView.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center" Padding="20" Spacing="10">
                            <Label Text="📝" FontSize="40" HorizontalOptions="Center"/>
                            <Label Text="История пока пуста" TextColor="#7F8C8D" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:HistoryItem">
                            <SwipeView>
                                <SwipeView.RightItems>
                                    <SwipeItems>
                                        <SwipeItem Text="Удалить" BackgroundColor="#E74C3C" 
                                                   Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.DeleteHistoryItemCommand}"
                                                   CommandParameter="{Binding .}"/>
                                    </SwipeItems>
                                </SwipeView.RightItems>

                                <ContentView Padding="0,0,0,10">
                                    <Border BackgroundColor="White" Padding="15" StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12" />
                                        </Border.StrokeShape>
                                        <Border.Shadow>
                                            <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.05"/>
                                        </Border.Shadow>

                                        <Grid ColumnDefinitions="*,Auto">
                                            <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                                                <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" TextColor="#2C3E50" LineBreakMode="TailTruncation"/>
                                                <Label Text="{Binding ScanTime}" FontSize="12" TextColor="#7F8C8D"/>
                                            </VerticalStackLayout>

                                            <Border Grid.Column="1" BackgroundColor="{Binding StatusColor}" Padding="10,5" StrokeThickness="0" VerticalOptions="Center">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="8" />
                                                </Border.StrokeShape>
                                                <Label Text="{Binding Status}" TextColor="White" FontSize="12" FontAttributes="Bold"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </ContentView>
                            </SwipeView>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label Text="Советы экспертов" FontAttributes="Bold" FontSize="18" TextColor="#2C3E50" />

                <HorizontalStackLayout x:Name="ArticlesSkeleton" Spacing="15" IsVisible="{Binding IsArticlesLoading}">
                    <StackLayout WidthRequest="160">
                        <BoxView Style="{StaticResource SkeletonBox}" HeightRequest="120" />
                        <BoxView Style="{StaticResource SkeletonBox}" HeightRequest="16" Margin="0,8,0,0" WidthRequest="140" HorizontalOptions="Start"/>
                        <BoxView Style="{StaticResource SkeletonBox}" HeightRequest="16" Margin="0,4,0,0" WidthRequest="100" HorizontalOptions="Start"/>
                    </StackLayout>
                    <StackLayout WidthRequest="160">
                        <BoxView Style="{StaticResource SkeletonBox}" HeightRequest="120" />
                        <BoxView Style="{StaticResource SkeletonBox}" HeightRequest="16" Margin="0,8,0,0" WidthRequest="140" HorizontalOptions="Start"/>
                    </StackLayout>
                </HorizontalStackLayout>

                <CollectionView ItemsSource="{Binding Articles}"
                                SelectedItem="{Binding SelectedArticle, Mode=TwoWay}"
                                HeightRequest="220"
                                SelectionMode="Single"
                                IsVisible="{Binding IsArticlesVisible}">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="15" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:RoskachestvoArticle">
                            <Border WidthRequest="160" BackgroundColor="White" StrokeThickness="0" Margin="0,0,0,10">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="16" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,4" Radius="6" Opacity="0.08"/>
                                </Border.Shadow>

                                <Grid RowDefinitions="120,*">
                                    <Image Source="{Binding Thumbnail}" Aspect="AspectFill" Grid.Row="0" />
                                    <Label Text="{Binding Title}" Grid.Row="1" Padding="12,10" FontSize="13" FontAttributes="Bold" TextColor="#2C3E50" LineBreakMode="WordWrap" MaxLines="3" VerticalOptions="Start" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label Text="Знак качества" FontAttributes="Bold" FontSize="18" TextColor="#2C3E50" />

                <VerticalStackLayout x:Name="QualitySkeleton" Spacing="10" IsVisible="{Binding IsQualityProductsLoading}">
                    <BoxView Style="{StaticResource SkeletonBox}" HeightRequest="70" />
                    <BoxView Style="{StaticResource SkeletonBox}" HeightRequest="70" />
                </VerticalStackLayout>

                <CollectionView ItemsSource="{Binding QualityProducts}"
                                SelectedItem="{Binding SelectedQualityProduct, Mode=TwoWay}"
                                SelectionMode="Single"
                                IsVisible="{Binding IsQualityProductsVisible}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="json:RskrfModels+QualityProduct">
                            <Border Margin="0,0,0,10" Padding="12" BackgroundColor="White" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.05"/>
                                </Border.Shadow>

                                <Grid ColumnDefinitions="45,*,Auto">
                                    <Frame Grid.Column="0" CornerRadius="8" HeightRequest="45" WidthRequest="45" Padding="0" IsClippedToBounds="True" BackgroundColor="#F8F9FA" BorderColor="Transparent">
                                        <Image Source="ros_quality.jpg" Aspect="AspectFit" Margin="5"/>
                                    </Frame>

                                    <Label Grid.Column="1" Text="{Binding Name}" FontSize="14" FontAttributes="Italic" VerticalOptions="Center" MaxLines="2" TextColor="#2C3E50" Margin="12,0,0,0" LineBreakMode="TailTruncation" />

                                    <Label Grid.Column="2" Text="❯" FontSize="16" TextColor="#BDC3C7" VerticalOptions="Center" FontAttributes="Bold"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>