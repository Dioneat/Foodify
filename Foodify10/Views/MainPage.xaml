<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Foodify10.ViewModels"
             xmlns:models="clr-namespace:Foodify10.Models"
             xmlns:json="clr-namespace:Foodify10.Models.JsonModels"
             x:Class="Foodify10.MainPage"
             x:Name="PageRoot"
             x:DataType="viewmodels:MainPageViewModel"
             BackgroundColor="#F8F9FA">

    <ContentPage.Resources>
        <Style x:Key="SkeletonBox" TargetType="BoxView">
            <Setter Property="BackgroundColor" Value="#E1E9EE" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="25">

                <Label Text="Недавние сканирования"
                       FontAttributes="Bold"
                       FontSize="18"
                       TextColor="#2C3E50"
                       Margin="20,20,20,10" />

                <Border BackgroundColor="#E8F8F5"
                        Padding="15"
                        Margin="20,10"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenShoppingListsCommand}" />
                    </Border.GestureRecognizers>

                    <Grid ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0"
                               Text="🛒"
                               FontSize="32"
                               VerticalOptions="Center"
                               Margin="0,0,15,0"/>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="Мои покупки"
                                   FontAttributes="Bold"
                                   FontSize="18"
                                   TextColor="#27AE60"/>
                            <Label Text="Нажмите, чтобы открыть списки"
                                   FontSize="12"
                                   TextColor="Gray"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <CollectionView ItemsSource="{Binding RecentScans}"
                                SelectedItem="{Binding SelectedHistoryItem, Mode=TwoWay}"
                                SelectionMode="Single"
                                Margin="20,0,20,0">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:HistoryItem">
                            <SwipeView>
                                <SwipeView.RightItems>
                                    <SwipeItems>
                                        <SwipeItem Text="Удалить"
                                                   BackgroundColor="Red"
                                                   Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.DeleteHistoryItemCommand}"
                                                   CommandParameter="{Binding .}"/>
                                    </SwipeItems>
                                </SwipeView.RightItems>

                                <ContentView Padding="0,0,0,10">
                                    <Border BackgroundColor="#FAFAFA"
                                            Padding="15"
                                            Stroke="#E0E0E0"
                                            StrokeThickness="1">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12" />
                                        </Border.StrokeShape>

                                        <Grid ColumnDefinitions="*,Auto">
                                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                                <Label Text="{Binding Name}"
                                                       FontAttributes="Bold"
                                                       FontSize="16"
                                                       TextColor="#2C3E50"
                                                       LineBreakMode="TailTruncation"/>
                                                <Label Text="{Binding ScanTime}"
                                                       FontSize="12"
                                                       TextColor="#7F8C8D"/>
                                            </VerticalStackLayout>

                                            <Border Grid.Column="1"
                                                    BackgroundColor="{Binding StatusColor}"
                                                    Padding="8,4"
                                                    StrokeThickness="0"
                                                    VerticalOptions="Center">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="8" />
                                                </Border.StrokeShape>

                                                <Label Text="{Binding Status}"
                                                       TextColor="White"
                                                       FontSize="12"
                                                       FontAttributes="Bold"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </ContentView>
                            </SwipeView>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="Советы экспертов Роскачества"
                       TextColor="Green"
                       Style="{StaticResource Headline}"
                       Margin="20,10" />

                <Grid Margin="20,10">
                    <CollectionView ItemsSource="{Binding Articles}"
                                    SelectedItem="{Binding SelectedArticle, Mode=TwoWay}"
                                    HeightRequest="220"
                                    SelectionMode="Single"
                                    IsVisible="{Binding IsArticlesVisible}">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:RoskachestvoArticle">
                                <Border WidthRequest="160"
                                        Padding="0"
                                        Margin="5"
                                        BackgroundColor="White"
                                        Stroke="#E0E0E0"
                                        StrokeThickness="1">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="15" />
                                    </Border.StrokeShape>

                                    <Grid RowDefinitions="100,*">
                                        <Image Source="{Binding Thumbnail}"
                                               Aspect="AspectFill"
                                               Grid.Row="0" />
                                        <Label Text="{Binding Title}"
                                               Grid.Row="1"
                                               Padding="10"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="Black"
                                               LineBreakMode="WordWrap"
                                               MaxLines="3" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <HorizontalStackLayout x:Name="ArticlesSkeleton"
                                           Spacing="10"
                                           IsVisible="{Binding IsArticlesLoading}">
                        <StackLayout WidthRequest="160">
                            <BoxView Style="{StaticResource SkeletonBox}" HeightRequest="100" />
                            <BoxView Style="{StaticResource SkeletonBox}" HeightRequest="20" Margin="0,5,0,0" WidthRequest="120" />
                            <BoxView Style="{StaticResource SkeletonBox}" HeightRequest="15" Margin="0,5,0,0" WidthRequest="80" />
                        </StackLayout>
                        <StackLayout WidthRequest="160">
                            <BoxView Style="{StaticResource SkeletonBox}" HeightRequest="100" />
                            <BoxView Style="{StaticResource SkeletonBox}" HeightRequest="20" Margin="0,5,0,0" WidthRequest="120" />
                        </StackLayout>
                    </HorizontalStackLayout>
                </Grid>

                <Label Text="Товары со знаком Роскачества"
                       TextColor="Green"
                       Style="{StaticResource Headline}"
                       Margin="20,20,20,10" />

                <Grid Margin="20,0">
                    <CollectionView ItemsSource="{Binding QualityProducts}"
                                    SelectedItem="{Binding SelectedQualityProduct, Mode=TwoWay}"
                                    SelectionMode="Single"
                                    Margin="20,0"
                                    IsVisible="{Binding IsQualityProductsVisible}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="json:RskrfModels+QualityProduct">
                                <Border Margin="0,0,0,10"
                                        Padding="10"
                                        BackgroundColor="White"
                                        Stroke="#DAE1E7"
                                        StrokeThickness="1">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12" />
                                    </Border.StrokeShape>

                                    <Grid ColumnDefinitions="40,*">
                                        <Image Source="ros_quality.jpg"
                                               WidthRequest="30"
                                               HeightRequest="30"
                                               VerticalOptions="Center" />

                                        <Label Grid.Column="1"
                                               Text="{Binding Name}"
                                               FontSize="14"
                                               VerticalOptions="Center"
                                               MaxLines="2"
                                               TextColor="Black"
                                               LineBreakMode="TailTruncation"
                                               Margin="10,0,0,0" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <VerticalStackLayout x:Name="QualitySkeleton"
                                         Spacing="10"
                                         IsVisible="{Binding IsQualityProductsLoading}">
                        <BoxView Style="{StaticResource SkeletonBox}" HeightRequest="60" />
                        <BoxView Style="{StaticResource SkeletonBox}" HeightRequest="60" />
                        <BoxView Style="{StaticResource SkeletonBox}" HeightRequest="60" />
                    </VerticalStackLayout>
                </Grid>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>